PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SEARCH_CH_API_KEY=your-search-ch-api-key
GOOGLE_PLACES_API_KEY=your-google-places-api-key
CRON_SECRET=your-cron-secret
ZEFIX_USERNAME=your-zefix-username
ZEFIX_PASSWORD=your-zefix-password
# Controle d'acces (connexion). Autorise si l'email est dans ALLOWED_EMAILS OU si son
# domaine est dans ALLOWED_DOMAINS (union). Au moins un des deux doit etre defini.
#
# Atelier 209 (decision Pascal 2026-07-15) : 4 ADRESSES NOMMEES, AUCUN domaine ouvert.
# Pourquoi pas de domaine : la RLS des tables de donnees est "mono-tenant plate" (tout
# compte authentifie lit/ecrit tout le PII client) ; faire confiance a un domaine entier
# donnerait a n'importe quelle boite (stagiaire@, catch-all@) un acces complet aux donnees.
# Un futur "user normal" s'ajoute par SON adresse ici (et durcir la RLS avant - watch M-48).
ALLOWED_EMAILS=pascal@filmpro.ch,antoine@filmpro.ch,pascal@lamaisoncreativedirection.ch,antoine@lamaisoncreativedirection.ch
ALLOWED_DOMAINS=

# Roles applicatifs (Atelier 209). Optionnel : si absent, les valeurs par defaut
# versionnees dans src/lib/server/roles.ts s'appliquent (Pascal admin, Antoine
# superuser, chacun sur ses deux adresses). Attention : la RLS reste sur les valeurs
# de la migration 20260715000000 — changer les roles reels = migration + deploiement.
# ADMIN_EMAILS=pascal@filmpro.ch,pascal@lamaisoncreativedirection.ch
# SUPERUSER_EMAILS=antoine@filmpro.ch,antoine@lamaisoncreativedirection.ch
