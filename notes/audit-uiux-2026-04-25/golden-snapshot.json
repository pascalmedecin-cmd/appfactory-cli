{
  "name": "CRM FilmPro",
  "version": "v2",
  "inspiration": "Extraction /prospection (gabarit exclusif) + arbitrage Pascal 2026-04-25",
  "tagline": "DM Sans + bleu primary + ambre signal, spacing Tailwind canonique, radius 10px, icônes Lucide",
  "_meta": {
    "source": "https://filmpro-crm.vercel.app/prospection (+ /veille)",
    "extracted_at": "2026-04-25",
    "extraction_method": "chrome MCP getComputedStyle, top frequency",
    "scope": "/prospection comme gabarit de vérité, /veille comme source palette uniquement",
    "supersedes": "v1 (extraction brute avec anomalies non arbitrées)",
    "decisions_applied": "2026-04-25 — 5 anomalies arbitrées par Pascal via HTML interactif"
  },
  "decisions": {
    "1": "Primary = bleu #2F5A9E (statu quo). Accent ambre #F79009 réservé aux signaux d'attention",
    "2": "Spacing aligné Tailwind canonique : 4 / 8 / 12 / 16 / 24 / 32 / 48 (retrait de 2, 6, 10, 20)",
    "3": "Hauteur boutons normalisée à 40px (h-10 Tailwind)",
    "4": "H1 sémantique obligatoire en haut de chaque page (rendu via classes Tailwind)",
    "5": "Migration CRM vers Lucide (override de la reco statu quo Material Symbols). Cohérence cross-projet avec formation-ia + gain perf -80kb. Voir tâche backlog."
  },
  "palette": {
    "background": "#FFFFFF",
    "surface": "#F9FAFB",
    "text": "#111827",
    "textMuted": "#6B7280",
    "border": "#E5E7EB",
    "primary": "#2F5A9E",
    "primaryHover": "#264C85",
    "accent": "#F79009",
    "accentBg": "#FFFAEB",
    "success": "#538B6B",
    "warning": "#F79009",
    "warningBg": "#FFFAEB",
