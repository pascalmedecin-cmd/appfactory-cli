    "buttons": "<button> ou <a> sémantique, jamais <div onclick>",
    "modals": "focus trap obligatoire, Escape ferme, return focus au déclencheur",
    "axeCore": "0 violation serious/critical en CI"
  },
  "rules": {
    "tableLayout": "table-fixed obligatoire pour respecter max-w (S48)",
    "stickyHeader": "tout sticky/fixed doit avoir bg opaque + séparateur (S45)",
    "batchActionsBar": "flex-wrap sous 640px obligatoire (S45)",
    "noAutreInLists": "jamais d'option « Autre » dans les select",
    "imageAspectRatio": "préserver le ratio source, jamais width+height forcés sans calcul",
    "iconLibrary": "lucide-svelte (post-migration, voir tâche backlog)",
    "headingSemantics": "H1 sémantique obligatoire au top de chaque page",
    "buttonHeight": "40px uniforme (h-10), box-sizing: border-box pour neutraliser bordures"
  }
