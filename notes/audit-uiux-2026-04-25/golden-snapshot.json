      "ardoise": "#5A7190",
      "violet": "#7B6A9A",
      "sauge": "#538B6B",
      "brun": "#917548"
    },
    "veillePale": "#EDF1F5",
    "comment": "Charte FilmPro complète disponible pour pages métier spécifiques (signaux, marchés). Ne pas utiliser hors scope défini."
